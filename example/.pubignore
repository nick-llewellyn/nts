# Slim the published tarball: exclude regenerable Flutter platform
# scaffolding, large icon-source assets, and developer-only tooling
# from the example app. The Dart source (lib/, bin/), pubspec, and
# consumer-facing documentation are kept so the example sources and
# the CLI/GUI guides remain readable to package consumers.
#
# A .pubignore in this directory replaces example/.gitignore for the
# purposes of `dart pub publish` (per dart.dev/go/pubignore). Patterns
# follow gitignore syntax. Hidden files, root .gitignore rules, and
# subdirectory .gitignore rules elsewhere in the tree still apply.

# Platform scaffolding (regenerable via `flutter create --platforms=...`)
android/
ios/
linux/
macos/
windows/

# Icon source assets (regenerable from tool/generate_icon.py)
assets/icon/

# Icon-generator tooling (consumers don't need it)
tool/

# Example app's analyzer configuration. Consumers run their own
# analyzer against their own code; this file does not influence their
# lints, so shipping it is noise on the package surface.
analysis_options.yaml

# Example app's test suite. Tests for the showcase apps belong in the
# repo for CI but do not help consumers learn the public API; the
# canonical entry point is example/main.dart.
test/

# Defensive: also covered by root .gitignore but listed for clarity
pubspec.lock
.dart_tool/
build/

# Carry over the non-redundant parts of the original example/.gitignore
# so we don't accidentally ship local IDE / build droppings if any
# happen to exist at publish time.
*.class
*.log
*.pyc
*.swp
*.iml
*.ipr
*.iws
migrate_working_dir/
**/doc/api/
app.*.symbols
app.*.map.json
